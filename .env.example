# ── ROARLINE configuration ────────────────────────────────────────────────────
# Copy to .env (or export in your shell). Everything has a sane default:
# with no .env at all, ROARLINE boots the authentic, hash-pinned France–Spain
# replay so anyone can experience the primary product in one command.

# Data source: "hero" (authentic pinned France–Spain replay), "txline"
# (live + historical API), or "sim" (synthetic engine lab; never primary UX).
ROARLINE_SOURCE=hero

# ── TxLINE (real data) ────────────────────────────────────────────────────────
# Network must be consistent end-to-end: origin, program, RPC.
#   devnet : https://txline-dev.txodds.com  ·  6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
#   mainnet: https://txline.txodds.com      ·  9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA
TXLINE_ORIGIN=https://txline.txodds.com
TXLINE_PROGRAM_ID=9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Produced by `npm run activate` (guest JWT auto-renews at runtime; the API
# token is the long-lived credential bound to your on-chain subscription).
TXLINE_API_TOKEN=

# Path to the Solana keypair JSON that signed the on-chain subscribe tx.
# Used by `npm run activate` and, when explicitly enabled, to sign custom
# MomentReceipt submissions. Guest JWT renewal does not use the wallet.
ROARLINE_WALLET=./wallet.json

# Free service level: 12 = real-time World Cup (mainnet), 1 = 60s-delayed.
TXLINE_SERVICE_LEVEL=12

# Proof-of-Broadcast receipts. Enable after deploying programs/roarline-receipts.
ROARLINE_RECEIPT_PROGRAM_ID=6d1Se4dj5yw11sDeT2Uss7iNVxuecHRMazZ1wgB32HFy
ROARLINE_RECEIPTS=0

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# Replay pacing when a viewer opens an archived match (wall-clock compression).
# 1 = real time. The UI also exposes 1x / 8x / 64x per viewer.
ROARLINE_REPLAY_SPEED=8
